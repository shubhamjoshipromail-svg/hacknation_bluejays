OPENAI_API_KEY=
# Optional; defaults to the model configured by the application.
OPENAI_MODEL=
OPENAI_EXTRACTOR_MODEL=gpt-5.6-luna
OPENAI_PLANNER_MODEL=gpt-5.6-terra
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_PHONE_NUMBER_ID=
TOOL_SHARED_SECRET=
CUSTOM_LLM_SHARED_SECRET=
ADMIN_SHARED_SECRET=
# ElevenLabs secret environment-variable label whose production value is CUSTOM_LLM_SHARED_SECRET.
ELEVENLABS_LLM_API_KEY_ENV_LABEL=negotiator_llm_api_key
CONVERSATION_CONTROLLER=hosted_tools
CONTROLLER_VERSION=1.0.0
PUBLIC_BASE_URL=https://your-tunnel.example
# Set this to the HMAC secret from the ElevenLabs post-call webhook settings.
ELEVENLABS_WEBHOOK_SECRET=
# This recovery build intentionally supports only explicit sandbox calling.
CALL_MODE=SANDBOX
# REAL mode remains blocked unless every destination has active provider opt-in evidence and NC jurisdiction.
PILOT_STATE=NC
CALL_WINDOW_LOCAL_START=09:00
CALL_WINDOW_LOCAL_END=17:00
CALL_DATA_RETENTION_DAYS=30
SANDBOX_PROVIDER_NAME=Sandbox Auto Glass Provider
SANDBOX_PROVIDER_NUMBER=+15555550123
# Optional additional authorized sandbox destinations. When configured, quote calls run sequentially.
SANDBOX_PROVIDER_2_NAME=Sandbox Auto Glass Provider 2
SANDBOX_PROVIDER_2_NUMBER=
SANDBOX_PROVIDER_3_NAME=Sandbox Auto Glass Provider 3
SANDBOX_PROVIDER_3_NUMBER=
# Legacy persona variables are evaluation-fixture only; they are never a product fallback.
PERSONA_PHONE_NUMBER_ID=
PERSONA_TO_NUMBER=
# Browser origin allowed by the API. Defaults to * for local/demo use.
FRONTEND_ORIGIN=http://localhost:3001
