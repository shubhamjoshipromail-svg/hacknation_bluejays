OPENAI_API_KEY=
# Optional; defaults to the model configured by the application.
OPENAI_MODEL=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_PHONE_NUMBER_ID=
TOOL_SHARED_SECRET=
PUBLIC_BASE_URL=https://your-tunnel.example
# Set this to the HMAC secret from the ElevenLabs post-call webhook settings.
ELEVENLABS_WEBHOOK_SECRET=
# This recovery build intentionally supports only explicit sandbox calling.
CALL_MODE=SANDBOX
SANDBOX_PROVIDER_NAME=Sandbox Auto Glass Provider
SANDBOX_PROVIDER_NUMBER=+15555550123
# Optional additional authorized sandbox destinations. When configured, quote calls run sequentially.
SANDBOX_PROVIDER_2_NAME=Sandbox Auto Glass Provider 2
SANDBOX_PROVIDER_2_NUMBER=
SANDBOX_PROVIDER_3_NAME=Sandbox Auto Glass Provider 3
SANDBOX_PROVIDER_3_NUMBER=
# Legacy persona variables are evaluation-fixture only; they are never a product fallback.
PERSONA_PHONE_NUMBER_ID=
PERSONA_TO_NUMBER=
# Backend port. The frontend expects :3000 unless you set VITE_API_URL.
PORT=3000
# Exact browser origin of the frontend, allowed by CORS. Must match where vite serves the UI.
FRONTEND_ORIGIN=http://localhost:8080
